OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3

# PubMed Configuration
PUBMED_API_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils # Might not be needed since we plan to use Biopython
PUBMED_EMAIL=myemail.personal@example.com
PUBMED_MAX_RESULTS=20

# Application Settings
APP_NAME=CapMed-Sci
DEBUG=True
LOG_LEVEL=INFO

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
 
# Server Configuration
HOST=0.0.0.0
PORT=8000
 
# Context Management
MAX_CONTEXT_TOKENS=120000
MAX_CONVERSATION_TURNS=5